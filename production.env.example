# =============================================================================
# PRODUCTION ENVIRONMENT TEMPLATE
# =============================================================================
# Copy this file to .env on your live server and update the values.
# IMPORTANT: Never share your production .env file.

APP_NAME="ZN International"
APP_ENV=production
APP_KEY=base64:gUsp6eEm7FF7HabcMjLot4sn2xtXVFTsiySCse0Wsbo=
APP_DEBUG=false
APP_URL=https://your-domain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=info

# Database Configuration
# Update these with your live MySQL/PostgreSQL credentials
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=zn_production
DB_USERNAME=zn_user
DB_PASSWORD=your_secure_password

# Session & Cache
SESSION_DRIVER=database
SESSION_LIFETIME=180
SESSION_ENCRYPT=false
CACHE_STORE=database
QUEUE_CONNECTION=database

# Mail Configuration
# Configure for your production mail provider (e.g., Mailgun, SMTP, etc.)
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"

# Stealth / Third Party Integrations
STEADFAST_BASE_URL="https://portal.packzy.com/api/v1"
STEADFAST_API_KEY="your_live_api_key"
STEADFAST_SECRET_KEY="your_live_secret_key"
STEADFAST_BEARER_TOKEN="your_live_webhook_token"

# Vite
VITE_APP_NAME="${APP_NAME}"
